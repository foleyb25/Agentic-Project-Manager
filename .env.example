# Local secrets for `uv run apm ...` — copy to `.env` (gitignored) and fill in
# yourself. NEVER commit real values; NEVER paste them into an AI chat.
# Real environment variables always take precedence over this file.
# CI does not use .env — set GitHub Actions secrets instead (docs/setup.md §3).

# Supabase ledger backend (PM's sole-writer credential)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# MCP tool surface (pm.tool_surface: mcp) — see mcp/pm.mcp.json
# GITHUB_MCP_TOKEN: GitHub PAT (repo/issues scope) for the hosted GitHub MCP
# SUPABASE_ACCESS_TOKEN: Supabase management PAT (sbp_..., Account -> Access Tokens)
# SUPABASE_PROJECT_REF: the project ref from your Supabase URL
# GITHUB_MCP_TOKEN=
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# Domain MCP servers for consultants (consult.mcp_config), e.g. Unreal editor:
# UNREAL_MCP_URL=http://127.0.0.1:8000/mcp

# GitHub repo override (usually auto-detected from the checkout via gh)
# GH_REPO=owner/repo

# CAUTION — leave unset for local runs: the claude CLI uses your interactive
# login (subscription seat) by default. Setting an API key here can switch
# local runs to API billing. Only set it if that's what you want.
# ANTHROPIC_API_KEY=

# Overrides without config edits:
# APM_LEDGER_BACKEND=jsonfile
# APM_ENGINE=cli
