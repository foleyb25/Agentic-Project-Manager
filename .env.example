# Local secrets for PM runs — copy to `.env` (gitignored) and fill in
# yourself. NEVER commit real values; NEVER paste them into an AI chat.
# Loaded by bin/pm-local.sh / bin/pm-local.ps1 (exported env always wins).
# CI does not use .env — set GitHub Actions secrets instead (docs/setup.md).

# Hosted GitHub MCP (issues read/write PAT — Actions GITHUB_TOKEN won't work)
GITHUB_MCP_TOKEN=

# Supabase MCP (management PAT sbp_..., Account -> Access Tokens) + project ref
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Domain MCP servers for consultants (e.g. Unreal editor), if tailored:
# UNREAL_MCP_URL=http://127.0.0.1:8000/mcp

# CAUTION — leave unset locally: the claude CLI uses your interactive login
# (subscription seat) by default. Setting an API key can switch local runs to
# API billing. CI sets it as an Actions secret instead.
# ANTHROPIC_API_KEY=
